# ── Secrets (fill in before running) ─────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Service ───────────────────────────────────────────────────────────────────
PORT=8081

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Browser ───────────────────────────────────────────────────────────────────
# Optional remote debugging URL for connecting to an existing browser instance (e.g. in Docker)
BROWSER_CDP_URL=
# Set to "false" to watch the browser window during local development
HEADLESS=true
# "chrome" uses the real Google Chrome binary (better anti-bot stealth).
# Leave empty to fall back to the bundled Chromium build (e.g. in Docker).
BROWSER_CHANNEL=chrome

# ── Anti-bot timing ───────────────────────────────────────────────────────────
# Minimal gap between agent actions — organic timing is provided by the
# human-mouse and human-typing patches (Bézier paths, hover dwell, keystroke
# delays), so no artificial wait is needed here.
WAIT_BETWEEN_ACTIONS=0.1
# Minimum seconds to wait after a page begins loading before interacting
MIN_PAGE_LOAD_WAIT=2.0

# ── Scraper limits ────────────────────────────────────────────────────────────
MAX_STEPS=30
MAX_URL_VISITS=5
ACTION_REPEAT_THRESHOLD=3

# ── reCAPTCHA solver ──────────────────────────────────────────────────────────
# Method: "audio" | "token" | "none"
#   audio – downloads the audio challenge, transcribes with OpenAI Whisper.
#           Falls back to token injection if Whisper fails (needs CAPTCHA_SOLVER_API_KEY too).
#   token – submits the site-key to 2captcha / anti-captcha and injects the response token.
#   none  – disabled; agent handles CAPTCHAs through system-prompt guidance only.
CAPTCHA_SOLVER=none
# OpenAI API key — required when CAPTCHA_SOLVER=audio
OPENAI_API_KEY=
# 2captcha or anti-captcha API key — required when CAPTCHA_SOLVER=token (or as audio fallback)
CAPTCHA_SOLVER_API_KEY=
# Which token service to use: "2captcha" or "anticaptcha"
CAPTCHA_SOLVER_SERVICE=2captcha
