# ── Secrets (fill in before running) ─────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Service ───────────────────────────────────────────────────────────────────
PORT=8081

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Browser ───────────────────────────────────────────────────────────────────
# Set to "false" to watch the browser window during local development
HEADLESS=true

# ── Scraper limits ────────────────────────────────────────────────────────────
MAX_STEPS=30
MAX_URL_VISITS=5
ACTION_REPEAT_THRESHOLD=3
